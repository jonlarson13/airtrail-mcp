{
  "name": "airtrail-mcp",
  "version": "0.1.0",
  "description": "MCP server for self-hosted AirTrail flight-tracking instances",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && node esbuild.config.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node server/index.js",
    "mcpb:pack": "npm run build && mcpb pack . airtrail-mcp.mcpb"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "tmp": "^0.2.7"
  }
}
